<resources>
    <style name="iOS14Theme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary color -->
        <item name="colorPrimary">@color/ios_blue</item>
        <item name="colorPrimaryVariant">@color/ios_blue</item>
        <item name="colorOnPrimary">@color/ios_white</item>
        
        <!-- Surface -->
        <item name="colorSurface">@color/ios_card</item>
        <item name="colorOnSurface">@color/ios_label</item>
        
        <!-- Background -->
        <item name="android:windowBackground">@color/ios_background</item>
        <item name="android:statusBarColor">@color/ios_background</item>
        <item name="android:windowLightStatusBar">true</item>
        
        <!-- Navigation bar -->
        <item name="android:navigationBarColor">@color/ios_background</item>
        <item name="android:windowLightNavigationBar">true</item>
        
        <!-- iOS 14 typography -->
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/ios_label</item>
        
        <!-- iOS 14 elevation -->
        <item name="android:elevation">0dp</item>
    </style>

    <!-- iOS 14 Button Style -->
    <style name="iOS14Button" parent="Widget.MaterialComponents.Button">
        <item name="android:textSize">17sp</item>
        <item name="android:textColor">@color/ios_white</item>
        <item name="android:padding">12dp</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="backgroundTint">@color/ios_blue</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">0dp</item>
    </style>

    <!-- iOS 14 Secondary Button -->
    <style name="iOS14ButtonSecondary" parent="iOS14Button">
        <item name="backgroundTint">@color/ios_light_gray</item>
        <item name="android:textColor">@color/ios_blue</item>
    </style>

    <!-- iOS 14 Destructive Button -->
    <style name="iOS14ButtonDestructive" parent="iOS14Button">
        <item name="backgroundTint">@color/ios_red</item>
    </style>

    <!-- iOS 14 Card -->
    <style name="iOS14Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/ios_card</item>
        <item name="android:background">@color/ios_card</item>
    </style>
</resources>
