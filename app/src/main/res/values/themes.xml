<resources>
    <style name="DeepSeekTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/ds_primary</item>
        <item name="colorPrimaryDark">@color/ds_primary_dark</item>
        <item name="colorAccent">@color/ds_primary</item>
        <item name="android:windowBackground">@color/ds_background</item>
        <item name="android:statusBarColor">@color/ds_status_bar</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:textColorPrimary">@color/ds_text_primary</item>
        <item name="android:textColorSecondary">@color/ds_text_secondary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="DeepSeekButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/ds_button_primary</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:padding">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:gravity">center</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="DeepSeekButtonSecondary" parent="DeepSeekButton">
        <item name="android:background">@drawable/ds_button_secondary</item>
        <item name="android:textColor">@color/ds_primary</item>
    </style>

    <style name="DeepSeekCard" parent="Widget.AppCompat.CardView">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/ds_surface</item>
        <item name="contentPadding">16dp</item>
    </style>

    <style name="DeepSeekTitle">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/ds_text_primary</item>
    </style>

    <style name="DeepSeekSubtitle">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/ds_text_secondary</item>
    </style>

    <style name="DeepSeekHeadline">
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/ds_text_primary</item>
    </style>
</resources>
