<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/ds_background"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Отчеты"
            style="@style/DeepSeekHeadline"
            android:textColor="@color/ds_text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Управляйте своими отчетами"
            style="@style/DeepSeekSubtitle"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/DeepSeekCard"
        android:layout_marginBottom="12dp"
        app:cardBackgroundColor="@color/ds_surface">

        <Button
            android:id="@+id/btnCreateReport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/create_report"
            style="@style/DeepSeekButton" />
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/DeepSeekCard"
        android:layout_marginBottom="12dp"
        app:cardBackgroundColor="@color/ds_surface">

        <Button
            android:id="@+id/btnReportsList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reports_list"
            style="@style/DeepSeekButton" />
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/DeepSeekCard"
        android:layout_marginBottom="12dp"
        app:cardBackgroundColor="@color/ds_surface">

        <Button
            android:id="@+id/btnCategories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/categories"
            style="@style/DeepSeekButton" />
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/DeepSeekCard"
        android:layout_marginBottom="12dp"
        app:cardBackgroundColor="@color/ds_surface">

        <Button
            android:id="@+id/btnFields"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/fields"
            style="@style/DeepSeekButton" />
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/DeepSeekCard"
        app:cardBackgroundColor="@color/ds_surface">

        <Button
            android:id="@+id/btnLogs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/logs"
            style="@style/DeepSeekButtonSecondary" />
    </androidx.cardview.widget.CardView>

</LinearLayout>
